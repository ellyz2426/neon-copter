    <text name="skin-2" fontSize="10" color="#ff44ff" cursor="pointer">[   ] Plasma Pink - 5K score</text>
    <text name="skin-3" fontSize="10" color="#4488ff" cursor="pointer">[   ] Frost Wing - 10 games</text>
    <text name="skin-4" fontSize="10" color="#00ff88" cursor="pointer">[   ] Toxic Green - x5 combo</text>
    <text name="skin-5" fontSize="10" color="#ffaa00" cursor="pointer">[   ] Royal Gold - 500m dist</text>
    <text name="skin-6" fontSize="10" color="#8844ff" cursor="pointer">[   ] Void Purple - All modes</text>
