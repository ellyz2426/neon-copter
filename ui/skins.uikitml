<root flexDirection="column" alignItems="center" gap="4" padding="10" backgroundColor="#000a18ee" borderRadius="8" borderWidth="1" borderColor="#ff44ff44" width="350">
  <text fontSize="18" fontWeight="bold" color="#ff44ff">COPTER SKINS</text>
  <container flexDirection="column" gap="3" width="100%">
    <text name="skin-0" fontSize="10" color="#00ffff" cursor="pointer">[ * ] Neon Cyan</text>
